{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2021"],
    "types": ["node"],
    "typeRoots": ["../node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "electron": ["../node_modules/electron"]
    }
  },
  "include": ["src/**/*.ts"]
}
